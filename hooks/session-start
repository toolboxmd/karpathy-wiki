#!/bin/bash
# SessionStart hook for karpathy-wiki.
#
# Responsibilities:
#   1. Detect if cwd (or a parent) contains a wiki; exit 0 silently if not.
#   2. Run drift check on raw/ — if new/modified sources, create captures.
#   3. Drain pending captures: spawn one detached ingester per capture.
#   4. Reclaim stale .processing files.
#   5. Emit ZERO model-visible context (stdout stays empty or '{}').
#
# Per superpowers-style-guide.md, we write to files (.ingest.log), never echo.

# NOTE: no `set -e` — we want best-effort execution; a failing drift-check
# should not prevent drain. Use `set -uo pipefail` for safer var handling.
set -uo pipefail

# v2.4 step 1: subagent / ingester fork-bomb guard.
# Skip the entire hook (no loader, no drift-scan, no drain) when:
#   - WIKI_CAPTURE is set (we are inside a spawned ingester; spawned ingesters
#     are themselves `claude -p` sessions which trigger SessionStart again —
#     without this guard, drift+drain re-runs inside every ingester, each
#     spawning N more, exploding to thousands of processes).
#   - CLAUDE_AGENT_PARENT is set (we are a subagent dispatched by another
#     agent; the wiki rules apply to the main agent only).
# WIKI_CAPTURE is set by wiki-spawn-ingester.sh on the headless worker's env.
if [[ -n "${WIKI_CAPTURE:-}" || -n "${CLAUDE_AGENT_PARENT:-}" ]]; then
  exit 0
fi

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${HOOK_DIR}/.." && pwd)"
# shellcheck source=/dev/null
source "${REPO_ROOT}/scripts/wiki-lib.sh"

# v2.4 step 2: loader injection (always runs, regardless of wiki presence).
# Reads skills/using-karpathy-wiki/SKILL.md and emits its body wrapped in
# <EXTREMELY_IMPORTANT> tags as hookSpecificOutput.additionalContext, so
# the agent sees the karpathy-wiki rules in every conversation.
LOADER_PATH="${REPO_ROOT}/skills/using-karpathy-wiki/SKILL.md"
if [[ -f "${LOADER_PATH}" ]]; then
  loader_content="$(cat "${LOADER_PATH}")"

  # Escape the loader content for JSON embedding.
  # Each ${s//old/new} is a single C-level pass — fast for large strings.
  escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
  }

  loader_escaped="$(escape_for_json "${loader_content}")"
  context_prefix='<EXTREMELY_IMPORTANT>\nYou have karpathy-wiki rules.\n\n**Below is the full content of the using-karpathy-wiki loader skill — auto-loaded into every conversation. For all other karpathy-wiki skills (capture, ingest), use the Skill tool when their moment arrives:**\n\n'
  context_suffix='\n</EXTREMELY_IMPORTANT>'

  # Claude Code expects hookSpecificOutput.additionalContext (nested).
  printf '{"hookSpecificOutput":{"additionalContext":"%s%s%s"}}' \
    "${context_prefix}" "${loader_escaped}" "${context_suffix}"
fi

# v2.4 step 3: wiki resolution (existing walk-up behavior).
# Steps 4-6 (drift-scan, drain, reclaim) only run if a wiki is found.
wiki="$(wiki_root_from_cwd 2>/dev/null || echo "")"
[[ -n "${wiki}" ]] || exit 0  # No wiki; loader already emitted, nothing else to do.

log_info "session-start: wiki=${wiki}"

# ---------------------------------------------------------------------------
# Drift check — detect new/modified files in raw/ and create drift captures.
# ---------------------------------------------------------------------------
# Wrapped in a function so we can use `local` for variables.
_drift_scan() {
  local drift_out
  drift_out="$(python3 "${REPO_ROOT}/scripts/wiki-manifest.py" diff "${wiki}" 2>/dev/null || echo "CLEAN")"
  [[ "${drift_out}" == "CLEAN" ]] && return 0

  log_info "session-start: drift detected"
  local line src capture_name capture_path src_hash
  while IFS= read -r line; do
    case "${line}" in
      NEW:\ *)      src="${line#NEW: }" ;;
      MODIFIED:\ *) src="${line#MODIFIED: }" ;;
      *)            continue ;;
    esac
    # Idempotency primitive: filename keyed on a content-stable hash of the
    # SRC path (not %H-%M, which collides under concurrent SessionStart
    # firings inside the same minute). Each unique src maps to exactly one
    # capture name, so two hooks racing on the same drift produce the same
    # filename — `set -C` (noclobber) below makes the create atomic.
    src_hash="$(printf '%s' "${src}" | shasum | cut -c1-12)"
    # Cap base length so absurdly long filenames stay under PATH_MAX, then
    # add the .md extension exactly once.
    capture_base="drift-${src_hash}-$(slugify "${src}")"
    capture_name="${capture_base:0:200}.md"
    capture_path="${wiki}/.wiki-pending/${capture_name}"
    # Atomic exclusive create. If two hooks race, only one wins; the other
    # sees a non-zero exit from `set -C` and we treat that as "already
    # captured this drift" — exactly the idempotency we want.
    if ( set -C; : > "${capture_path}" ) 2>/dev/null; then
      # Body must clear the 200-byte floor for evidence_type: file. The
      # ingester reads the raw file separately; the body's job is to give it
      # context — what changed, why this isn't a chat capture, what the
      # ingester should do (read the raw, infer category, decide create vs
      # update). Without enough body the ingester rejects with
      # needs_more_detail and the capture rots in .wiki-pending/ forever.
      cat > "${capture_path}" <<EOF
---
title: "Drift: ${src}"
evidence: "${wiki}/${src}"
evidence_type: "file"
suggested_action: "update"
suggested_pages: []
captured_at: "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
captured_by: "session-start-drift"
origin: null
---

Auto-generated drift capture. The raw source file at \`${src}\` is either
new (not yet in \`.manifest.json\`) or its sha256 has changed since the last
ingest. This capture exists so the next ingester run brings the wiki back
in sync with what's actually on disk in \`raw/\`.

Action for the ingester: read the raw file at \`evidence\`, decide which
existing page (if any) it augments based on its content, and either update
that page or create a new one in the appropriate category. Update the
manifest entry for this raw file once done so this drift doesn't re-fire
on the next session-start. If the raw file looks like an Obsidian Web
Clipper export (has source/created/published frontmatter), preserve those
fields when copying.
EOF
      log_info "session-start: drift capture created: ${capture_name}"
    fi
  done <<< "${drift_out}"
}
_drift_scan || log_warn "session-start: drift scan failed (non-fatal)"

# ---------------------------------------------------------------------------
# Drain pending captures — spawn a detached ingester per capture.
# ---------------------------------------------------------------------------
_drain_pending() {
  local count=0
  local f
  for f in "${wiki}/.wiki-pending"/*.md; do
    [[ -f "${f}" ]] || continue
    [[ "${f}" == *.processing ]] && continue
    count=$((count + 1))
  done
  [[ "${count}" -eq 0 ]] && return 0

  log_info "session-start: draining ${count} pending captures"
  for f in "${wiki}/.wiki-pending"/*.md; do
    [[ -f "${f}" ]] || continue
    [[ "${f}" == *.processing ]] && continue
    bash "${REPO_ROOT}/scripts/wiki-spawn-ingester.sh" "${wiki}" "${f}" &
    disown 2>/dev/null || true
  done
}
_drain_pending || log_warn "session-start: drain failed (non-fatal)"

# ---------------------------------------------------------------------------
# Reclaim stale .processing files (> 10 min): rename back to .md so next
# opportunity can pick them up.
# ---------------------------------------------------------------------------
_reclaim_stale() {
  local proc mtime now age
  while IFS= read -r proc; do
    [[ -z "${proc}" ]] && continue
    mtime="$(stat -f %m "${proc}" 2>/dev/null || stat -c %Y "${proc}" 2>/dev/null || echo 0)"
    now="$(date +%s)"
    age=$((now - mtime))
    if [[ "${age}" -gt 600 ]]; then
      log_warn "session-start: reclaiming stale processing: $(basename "${proc}")"
      mv "${proc}" "${proc%.processing}" || true
    fi
  done < <(find "${wiki}/.wiki-pending" -maxdepth 1 -name "*.md.processing" -type f 2>/dev/null)
}
_reclaim_stale || log_warn "session-start: stale reclaim failed (non-fatal)"

# Emit empty context per superpowers style guide (issue #1220 cost lesson).
# Exit 0. Do NOT echo anything.
exit 0
